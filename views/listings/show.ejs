<%layout("/layouts/boilerplate.ejs")%>
<body>
  <div class="show-div">
    <h2><%=listing.title%></h2>
    <div class="img"><img src="<%=listing.image%>" alt="" /></div>
    <div class="show-info">
      <p>Owned By: <b><i><%=listing.owner.username%></i></b></p>
      <%=listing.description%> <br />
      &#x20B9;<%=listing.price.toLocaleString("en-in")%> <br />
      <%=listing.location%> <br />
      <%=listing.country%>
    </div>
   <%if(currUser && listing.owner.equals(currUser._id)){%>
    <div class="buttons">
      <form method="get" action="/listings/<%=listing._id%>/edit">
        <button class="btn btn-dark">Edit</button>
      </form>
      <form method="post" action="/listings/<%=listing._id%>?_method=delete">
        <button class="btn btn-dark">DELETE</button>
      </form>
    </div>
    <%}%>
    <%if(currUser){%>
    <hr>
    <div class="review mt-4">
      <h4>Leave a Review</h4>
      <form method="post" action="/listings/<%=listing._id%>/review" class="needs-validation" novalidate>
        <div class="rating">
        <b>Rating: <output for="rating" id="rangeValue" aria-hidden="true"></output></b>
        <input type="range" class="form-range" min="1" max="5" value="1" id="rating" name="review[rating]">
      </div>
        <div class="mb-3">
      <label for="comment" class="form-label">Comment</label>
      <textarea type="text" class="form-control" placeholder="Leave your Comments..." name="review[comment]" required></textarea>
      <div class="valid-feedback">comment looks good!</div>
      <div class="invalid-feedback">Enter your comment</div>
      <br>
      <button type="submit" class="btn btn-outline-dark">Submit</button>
      </form>
    </div>
    <%}%>
    <hr>
    <h4>All Reviews</h4>
      <div class="row">
        <%for(review of listing.reviews){%>
        <div class="card col-5 mb-5 ms-5 review-card">
          <div class="card-body">
          <h5 class="card-title">@<%=review.author.username%></h5>
           <p class="card-text"><%=review.comment%></p>
            <p class="card-text"><%=review.rating%> stars</p>
          </div>
          <form method="post"  action="/listings/<%=listing._id%>/review/<%=review._id%>?_method=DELETE">
            <%if(review && review.author.equals(currUser._id)){%>
            <button class="btn btn-outline-dark mb-3 ms-3 review-delete-btn">Delete</button>
            <%}%>
          </form>
        </div>
      <%}%>
      </div>
  </div>
  <script>
  // This is an example script, please modify as needed
  const rangeInput = document.getElementById('rating');
  const rangeOutput = document.getElementById('rangeValue');

  // Set initial value
  rangeOutput.textContent = rangeInput.value;

  rangeInput.addEventListener('input', function() {
    rangeOutput.textContent = this.value;
  });
</script>
</body>
